{
  "name": "site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target browser && cp index.html dist/index.html",
    "dev": "bun build ./src/index.ts --outdir dist --target browser --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2"
  }
}
